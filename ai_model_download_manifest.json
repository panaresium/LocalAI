  "baseline_install_order": [
    {
      "type": "runtime",
      "name": "Ollama for Windows",
      "url": "https://ollama.com/download/windows",
      "windows_command": "irm https://ollama.com/install.ps1 | iex"
    },
    {
      "type": "runtime",
      "name": "Hermes Agent",
      "url": "https://hermes-agent.nousresearch.com/docs/getting-started/installation",
      "windows_command": "iex (irm https://hermes-agent.nousresearch.com/install.ps1)"
    }
  ],
